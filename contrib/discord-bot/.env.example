# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-discord-bot-token

# Pulpod daemon URL
PULPOD_URL=http://localhost:7433

# Pulpod API token (from ~/.pulpo/config.toml [auth] section)
PULPOD_TOKEN=your-pulpod-token

# Discord channel ID for SSE event notifications (optional)
# If not set, events are posted to the channel where /spawn was used
DISCORD_NOTIFICATION_CHANNEL_ID=
