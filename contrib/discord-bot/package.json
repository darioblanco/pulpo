{
  "name": "pulpo-discord-bot",
  "version": "0.1.0",
  "description": "Discord bot for controlling pulpod agent sessions",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "fmt": "prettier --write 'src/**/*.ts'",
    "fmt:check": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "discord.js": "^14.16.0",
    "eventsource": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
