# Pulpo node settings
PULPO_NODE_NAME=pulpo-worker-1
PULPO_BIND=lan
PULPO_PORT=7433
PULPO_TOKEN=replace-with-long-random-token
PULPO_GUARD_PRESET=strict

# Optional agent/provider credentials
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
CODEX_OAUTH_TOKEN=
OPENAI_API_KEY=

# Optional git identity / SSH
GIT_AUTHOR_NAME=Pulpo Agent
GIT_AUTHOR_EMAIL=agent@example.com
GIT_SSH_PRIVATE_KEY_B64=

# Optional Discord webhook passthrough
DISCORD_WEBHOOK_URL=
DISCORD_EVENTS=running,completed,dead,fired,failed
