#!/usr/bin/env bash
set -euo pipefail

echo "==> Pre-commit: checking formatting..."
cargo fmt --all -- --check
(cd web && npx prettier --check .)

echo "==> Pre-commit: running clippy..."
cargo clippy --workspace --all-targets -- -D warnings

echo "==> Pre-commit: running ESLint + TypeScript check..."
(cd web && npx eslint . && npx tsc --noEmit)

echo "==> Pre-commit: running tests..."
cargo test --workspace
(cd web && PATH=/usr/local/bin:$PATH NODE_OPTIONS=--experimental-require-module NODE_PATH=./vendor npx vitest run --passWithNoTests)

echo "==> Pre-commit: checking Rust coverage..."
make coverage-rust

echo "==> All checks passed."
